# ─── ClawChives Environment Configuration ─────────────────────────────────────
# Copy this file to .env and uncomment the desired settings.
# NEVER commit your .env file to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database Mode ──────────────────────────────────────────────────────────────
# INDEXEDDB   No server required. All data stored in the browser.
#             Works on GitHub Pages, Netlify, Vercel, any static host.
#
# SQLITE      Requires Docker (docker-compose --profile sqlite up)
#             or a running server.js (node server.js).
#             Data is stored in ./data/db.sqlite.

VITE_DATABASE=INDEXEDDB

# ── API Server URL ─────────────────────────────────────────────────────────────
# Only relevant when VITE_DATABASE=SQLITE.
# Change the host/port if your server.js runs elsewhere.

VITE_API_URL=http://localhost:4242
