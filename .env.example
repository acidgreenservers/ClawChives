# ─── ClawChives Environment Configuration ─────────────────────────────────────
# Copy this file to .env and uncomment the desired settings.
# NEVER commit your .env file to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── API Server URL ─────────────────────────────────────────────────────────────
# Required for connecting the frontend to the backend server.
# Change the host/port if your server.js runs elsewhere.

VITE_API_URL=http://localhost:4242

# ── Security ──────────────────────────────────────────────────────────────────
# Enable "trust proxy" if the server is behind a trusted reverse proxy (e.g., Nginx, Docker, LB)
# This is required for correct IP detection when using rate limiting or HTTPS redirection.
# TRUST_PROXY=true
