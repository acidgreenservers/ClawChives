# ─── ClawChives Environment Configuration ─────────────────────────────────────
# Copy this file to .env and uncomment the desired settings.
# NEVER commit your .env file to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── API Server URL ─────────────────────────────────────────────────────────────
# Required for connecting the frontend to the backend server.
#
# Local Dev:        http://localhost:4646       (npm start / scuttle:dev-start)
# LAN/Self-Hosted:  http://192.168.1.6:4646    (Replace IP with your machine's LAN IP)
# Docker:           Leave unset (uses relative paths, same-origin)
# Custom Domain:    https://bookmarks.yourdomain.com

VITE_API_URL=http://localhost:4646

# ── Security ──────────────────────────────────────────────────────────────────
# Enable "trust proxy" if the server is behind a trusted reverse proxy (e.g., Nginx, Docker, LB)
# This is required for correct IP detection when using rate limiting or HTTPS redirection.
# TRUST_PROXY=true

# ── CORS Configuration ────────────────────────────────────────────────────────
# Controls which origins can make requests to the API.
#
# LAN/Self-Hosted (default):
#   Leave unset — automatically allows any private IP (192.168.x.x, 10.x.x.x, localhost)
#   Works with docker-compose 0.0.0.0 binding
#
# Reverse Proxy / Cloudflare Tunnel:
#   Set to your public domain — only that origin is allowed
#   CORS_ORIGIN=https://bookmarks.yourdomain.com
#
# Multiple origins (comma-separated):
#   CORS_ORIGIN=https://bookmarks.yourdomain.com,http://localhost:4545
#
# CORS_ORIGIN=

# ── Data Storage ───────────────────────────────────────────────────────────────
# Path to SQLite database directory (default: ./data)
# DATA_DIR=./data

# ── Database Encryption (SQLCipher / ShellCryption™) ──────────────────────────
# AES-256 encryption for the SQLite database file at rest.
# Generate a secure key with: openssl rand -base64 32
# Leave unset for plaintext database (NOT recommended for production).
# WARNING: DB_ENCRYPTION_KEY in docker-compose.yml is visible via `docker inspect`.
# For stronger key protection on shared systems, use Docker Secrets instead.
# DB_ENCRYPTION_KEY=

# ── HTTPS / TLS (Optional) ─────────────────────────────────────────────────────
# Only needed if deploying to public internet WITHOUT a reverse proxy.
# For LAN deployments or behind CF tunnel/nginx, leave unset.
#
# ENFORCE_HTTPS=false
# HTTPS_PORT=4647

# ── Token Configuration ────────────────────────────────────────────────────────
# Default TTL for API tokens (in minutes). Default: 1440 (24 hours)
# TOKEN_TTL_DEFAULT=1440

# ── Rate Limiting (Optional) ───────────────────────────────────────────────────
# Auth endpoint rate limiting (prevents brute force)
# AUTH_RATE_WINDOW=900000        # 15 minutes (ms)
# AUTH_RATE_LIMIT=5              # Max 5 attempts per window

# API endpoint rate limiting (prevents abuse)
# API_RATE_WINDOW=60000          # 1 minute (ms)
# API_RATE_LIMIT=100             # Max 100 requests per window
