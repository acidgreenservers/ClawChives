{
  "name": "claw-chives",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx --watch server.ts",
    "scuttle:prod-start": "npm run build && NODE_ENV=production tsx server.ts & vite preview &",
    "scuttle:dev-start": "npm run dev:server & npm run dev &",
    "scuttle:prod-stop": "fuser -k 4545/tcp 4646/tcp || true",
    "scuttle:dev-stop": "npm run scuttle:prod-stop",
    "scuttle:reset": "tsx scripts/scuttle-reset.ts --env production",
    "scuttle:reset-dev": "tsx scripts/scuttle-reset.ts --env development",
    "start:api": "tsx server.ts",
    "build": "tsc && vite build",
    "lint": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:phase3:build": "vitest run tests/build-gates.test.ts",
    "test:phase3:integration": "vitest run tests/phase3-integration.test.ts",
    "test:phase3:full": "npm run test && npm run test:phase3:integration && npm run test:phase3:build",
    "test:lobster-session": "vitest run tests/lobster-session.test.ts",
    "test:phase4:full": "npm run test && npm run test:lobster-session && npm run test:phase3:build"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-virtual": "^3.13.23",
    "better-sqlite3-multiple-ciphers": "^9.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "framer-motion": "^12.36.0",
    "helmet": "^8.1.0",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-intersection-observer": "^10.0.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "postcss": "^8.4.38",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.2.2",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
